# === ENVIRONMENT CONFIGURATION ===
NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# === DATABASE ===
DATABASE_URL=postgresql://momfriend:password@localhost:5432/momfriend

# === REDIS CACHE ===
REDIS_URL=redis://localhost:6379

# === JWT AUTHENTICATION ===
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=24h
REFRESH_TOKEN_SECRET=your-refresh-token-secret
REFRESH_TOKEN_EXPIRES_IN=7d

# === AWS SERVICES ===
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=eu-west-1
AWS_S3_BUCKET=momfriend-uploads

# === EMAIL SERVICE (Nodemailer) ===
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# === SMS SERVICE (Twilio) ===
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1234567890

# === CORS ORIGINS ===
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# === RATE LIMITING ===
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
AUTH_RATE_LIMIT_MAX=5

# === FILE UPLOAD ===
MAX_FILE_SIZE=10485760
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/gif

# === VERIFICATION SERVICES ===
ID_VERIFICATION_API_KEY=your-id-verification-api-key
FACE_RECOGNITION_API_KEY=your-face-recognition-api-key

# === MONITORING ===
SENTRY_DSN=your-sentry-dsn
ANALYTICS_API_KEY=your-analytics-api-key

# === SOCIAL LOGIN ===
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
APPLE_CLIENT_ID=your-apple-client-id
APPLE_CLIENT_SECRET=your-apple-client-secret

# === PUSH NOTIFICATIONS ===
FCM_SERVER_KEY=your-fcm-server-key
APN_KEY_ID=your-apn-key-id
APN_TEAM_ID=your-apn-team-id

# === CONTENT MODERATION ===
OPENAI_API_KEY=your-openai-api-key
CONTENT_MODERATION_THRESHOLD=0.8

# === GEOLOCATION ===
GOOGLE_MAPS_API_KEY=your-google-maps-api-key
MAX_DISTANCE_KM=50

# === FEATURES FLAGS ===
ENABLE_SOCIAL_LOGIN=true
ENABLE_ID_VERIFICATION=true
ENABLE_PUSH_NOTIFICATIONS=true
ENABLE_CONTENT_MODERATION=true
ENABLE_ANALYTICS=true 