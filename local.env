# MomFriend Local Development Configuration
# Automatycznie generowany przez start-local.sh

# === SERVER ===
NODE_ENV=development
PORT=3000
HOST=localhost
LOG_LEVEL=debug

# === DATABASE ===
DATABASE_URL=postgresql://postgres:postgres123@localhost:5432/momfriend
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=momfriend
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres123

# === REDIS ===
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=""

# === JWT AUTHENTICATION ===
JWT_SECRET=mom-friend-local-secret-key-2025-very-long-and-secure
JWT_EXPIRES_IN=24h
REFRESH_TOKEN_SECRET=mom-friend-refresh-token-secret-2025
REFRESH_TOKEN_EXPIRES_IN=7d

# === CORS ===
CORS_ORIGINS=http://localhost:3000,http://localhost:8080,http://localhost:3001,http://127.0.0.1:3000

# === RATE LIMITING ===
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=1000
AUTH_RATE_LIMIT_MAX=10

# === FILE UPLOAD ===
MAX_FILE_SIZE=10485760
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/gif,image/webp

# === LOCAL DEVELOPMENT FLAGS ===
ENABLE_DEBUG_ROUTES=true
ENABLE_CORS=true
DISABLE_AUTH_FOR_TESTING=false
ENABLE_REQUEST_LOGGING=true

# === MOCK/TEST DATA ===
ENABLE_MOCK_DATA=true
MOCK_USER_COUNT=10
ENABLE_TEST_ENDPOINTS=true

# === AWS (Leave empty for local) ===
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_REGION=eu-west-1
AWS_S3_BUCKET=""

# === EMAIL (Leave empty for local) ===
SMTP_HOST=""
SMTP_PORT=587
SMTP_USER=""
SMTP_PASS=""

# === SMS (Leave empty for local) ===
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_PHONE_NUMBER=""

# === EXTERNAL APIS (Leave empty for local) ===
GOOGLE_MAPS_API_KEY=""
OPENAI_API_KEY=""
ID_VERIFICATION_API_KEY=""

# === MONITORING ===
SENTRY_DSN=""
ANALYTICS_API_KEY=""

# === FEATURES (Local Development) ===
ENABLE_SOCIAL_LOGIN=false
ENABLE_ID_VERIFICATION=false
ENABLE_PUSH_NOTIFICATIONS=false
ENABLE_CONTENT_MODERATION=false
ENABLE_ANALYTICS=false
ENABLE_GEOLOCATION=true 